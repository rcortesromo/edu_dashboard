{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/data/*", "*.{css,js,json,png,jpg,jpeg,gif,svg,ico,woff,woff2,ttf,eot,map,webp,avif}"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
