{
  "sourceSystem": "Jira",
  "quarterConvention": "calendar",
  "fields": {
    "sprintFieldId": "customfield_10020",
    "teamFieldId": "customfield_10032",
    "storyPointsFieldId": "customfield_10043",
    "severityFieldId": "customfield_10121",
    "rootCauseFieldId": "customfield_10102",
    "workTypeFieldId": "customfield_10371",
    "statusFieldName": "status",
    "issueTypeFieldName": "issuetype"
  },
  "issueScope": {
    "includeIssueTypes": ["Story", "Bug", "Task"],
    "excludeIssueTypes": ["Epic", "Sub-task"]
  },
  "teamMapping": {
    "strategy": "jira_field",
    "notes": "The same Jira Team field is used for all tracked teams. Team scope is centralized below."
  },
  "boardsOrProjects": [
    {
      "teamName": "Team Webstore",
      "boardId": "175",
      "projectKeys": ["OV"],
      "workItemScope": {
        "includeIssueTypes": ["Story", "Bug", "Task"],
        "excludeIssueTypes": ["Epic", "Sub-task"]
      },
      "velocity": {
        "sourceType": "calculated_completed_points",
        "velocityScope": "committed_only",
        "sprintNameRegex": "^WS\\d{2}Q\\dS\\d+"
      },
      "cycleTime": {
        "startType": "status_name",
        "startValue": "In Development",
        "endType": "status_category",
        "endValue": "Done"
      }
    },
    {
      "teamName": "Team Connexpoint",
      "boardId": "170",
      "projectKeys": ["OV"],
      "workItemScope": {
        "includeIssueTypes": ["Sub-task"],
        "excludeIssueTypes": ["Epic"]
      },
      "velocity": {
        "sourceType": "calculated_completed_points",
        "velocityScope": "committed_only",
        "velocityIssueTypes": ["Story", "Bug", "Task"],
        "sprintNameRegex": "^CXP\\d{2}Q\\d\\s-\\s(Sprint|Sp)\\s\\d+"
      },
      "cycleTime": {
        "startType": "status_name",
        "startValue": "In Development",
        "endType": "status_category",
        "endValue": "Done"
      }
    },
    {
      "teamName": "Team ASAP",
      "boardId": "174",
      "projectKeys": ["OV"],
      "workItemScope": {
        "includeIssueTypes": ["Story", "Bug", "Task"],
        "excludeIssueTypes": ["Epic", "Sub-task"]
      },
      "velocity": {
        "sourceType": "calculated_completed_points",
        "velocityScope": "committed_only",
        "sprintNameRegex": "^ASAP\\s-\\s\\d{2}Q\\dS[1-9]\\d*"
      },
      "cycleTime": {
        "startType": "status_name",
        "startValue": "In Development",
        "endType": "status_category",
        "endValue": "Done"
      }
    },
    {
      "teamName": "Team Smartcare",
      "boardId": "198",
      "projectKeys": ["OV"],
      "workItemScope": {
        "includeIssueTypes": ["Story", "Bug", "Task"],
        "excludeIssueTypes": ["Epic", "Sub-task"]
      },
      "velocity": {
        "sourceType": "calculated_completed_points",
        "velocityScope": "committed_only",
        "sprintNameRegex": "^VC\\s\\d{2}Q\\dS[1-9]\\d*"
      },
      "cycleTime": {
        "startType": "status_name",
        "startValue": "In Development",
        "endType": "status_category",
        "endValue": "Done"
      }
    }
  ],
  "defectLeakage": {
    "issueType": "Bug",
    "projectKeys": ["OV"],
    "createdFrom": "2025-01-01",
    "severityNumeratorLevels": ["Level 1", "Level 2"],
    "reopenedStatusNames": ["Reopened"],
    "portfolioTeamName": "EDU",
    "teams": [
      { "jiraTeamName": "Team Connexpoint", "outputTeamName": "Team Connexpoint" },
      { "jiraTeamName": "Team Webstore", "outputTeamName": "Team Webstore" },
      { "jiraTeamName": "Team ASAP", "outputTeamName": "ASAP" },
      { "jiraTeamName": "Team Smartcare", "outputTeamName": "Smartcare" }
    ]
  },
  "mttr": {
    "createdFrom": "2025-01-01",
    "projectKeys": ["OV"],
    "issueTypes": ["Bug", "Story", "Task"],
    "severityLevels": ["Level 1", "Level 2"],
    "endStatus": "Closed",
    "businessDaysOnly": true,
    "portfolioTeamName": "EDU",
    "teams": [
      { "jiraTeamName": "Team Connexpoint", "outputTeamName": "Team Connexpoint" },
      { "jiraTeamName": "Team Webstore", "outputTeamName": "Team Webstore" },
      { "jiraTeamName": "Team ASAP", "outputTeamName": "ASAP" },
      { "jiraTeamName": "Team Smartcare", "outputTeamName": "Smartcare" }
    ]
  },
  "workTypeMix": {
    "createdFrom": "2025-01-01",
    "projectKeys": ["OV"],
    "portfolioTeamName": "EDU",
    "notes": "Maintain/Run/Growth mix of logged worklog hours, bucketed by the Work Type field. Population is every OV issue with a worklog entry in the period, regardless of issue type (Story/Bug/Task/Sub-task) so Team Connexpoint's sub-task-tracked work is included.",
    "categories": {
      "Maintain": ["M - Prod (Sev 1)", "M - Maintenance", "M - Tech Hardening"],
      "Run": ["R - Client Request", "R - Strategic"],
      "Growth": ["G - Experiment/Growth"]
    },
    "teams": [
      { "jiraTeamName": "Team Connexpoint", "outputTeamName": "Team Connexpoint" },
      { "jiraTeamName": "Team Webstore", "outputTeamName": "Team Webstore" },
      { "jiraTeamName": "Team ASAP", "outputTeamName": "ASAP" },
      { "jiraTeamName": "Team Smartcare", "outputTeamName": "Smartcare" }
    ]
  }
}
