{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EduDashboardMetrics",
  "type": "object",
  "required": ["reportDate", "teams", "quarters", "sprintCalendar", "metrics"],
  "properties": {
    "reportDate": {
      "type": "string",
      "format": "date"
    },
    "teams": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "quarters": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{4}-(Q[1-4]|YTD)$"
      },
      "uniqueItems": true
    },
    "sprintCalendar": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["key", "sequence", "name", "start", "end"],
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[0-9]{4}-Q[1-4]-S[0-9]+$"
              },
              "sequence": {
                "type": "integer",
                "minimum": 1
              },
              "name": {
                "type": "string"
              },
              "start": {
                "type": "string",
                "format": "date"
              },
              "end": {
                "type": "string",
                "format": "date"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "team",
          "quarter",
          "metricName",
          "value",
          "unit",
          "source",
          "automationStatus",
          "note",
          "lastRefreshUtc"
        ],
        "properties": {
          "team": {
            "type": "string"
          },
          "quarter": {
            "type": "string",
            "pattern": "^[0-9]{4}-(Q[1-4](-S[0-9]+)?|YTD)$"
          },
          "metricName": {
            "type": "string",
            "enum": [
              "Jira Card Churn %",
              "Defect Leakage %",
              "Sev 1 Bugs",
              "Sev 2 Bugs",
              "Sev 1 + Sev 2 Bugs",
              "Sev 1 Bugs (Internal)",
              "Sev 1 Bugs (External)",
              "Sev 2 Bugs (Internal)",
              "Sev 2 Bugs (External)",
              "MTTR (Sev 1 + Sev 2)",
              "MTTR Avg (Sev 1 + Sev 2)",
              "MTTR Tickets (Sev 1 + Sev 2)",
              "Average Velocity (points per sprint)",
              "Flow-based Cycle Time Proxy (weeks)",
              "Actual Cycle Time (weeks)",
              "Cursor Adoption Rate",
              "AI-assisted Pull Request Coverage",
              "AI Active Developers"
            ]
          },
          "value": {
            "type": "number"
          },
          "unit": {
            "type": "string",
            "enum": ["percent", "weeks", "points", "count", "hours"]
          },
          "source": {
            "type": "string",
            "enum": ["Jira", "GitHub", "Cursor"]
          },
          "automationStatus": {
            "type": "string",
            "enum": ["Yes", "Yes (partial)", "No", "automated"]
          },
          "note": {
            "type": "string"
          },
          "lastRefreshUtc": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
